{
  "description": "Helix learning system hooks - extract insights and apply feedback on agent completion",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/setup-env.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/lib/hooks/session_end.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "helix:helix-builder|helix:helix-planner",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/lib/hooks/inject_memory.py",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "helix:helix-.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/lib/hooks/extract_learning.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
